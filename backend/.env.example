# Backend environment variables — copy to backend/.env and fill in.
# .env is gitignored and never committed.

# LLM provider (any one — Groq is fastest)
GROQ_API_KEY=
# ANTHROPIC_API_KEY=

# Bearer token gating every non-/health endpoint. Generate a random
# 32+ char string. Frontend must inject the same value via the proxy.
BACKEND_API_TOKEN=

# Optional region override; default is ap-southeast-2.
# AWS_REGION=ap-southeast-2
